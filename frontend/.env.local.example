# ---- Frontend configuration (copy to .env.local and fill in) ----
# NOTE: Vite inlines these at BUILD time and ships them in the client bundle.
# Only put PUBLIC values here (never the Supabase service-role key).

# Base URL of the backend API (no trailing /api/v1 — the app adds it).
# Local:      http://localhost:8000
# Production: https://your-backend.fly.dev
VITE_API_URL=http://localhost:8000

# Supabase project URL and the PUBLIC anon/publishable key (safe to expose).
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>
