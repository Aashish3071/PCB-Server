# ---- Backend configuration (copy to .env and fill in) ----

# Runtime environment: "development" or "production".
# In production, interactive API docs (/api/docs, /api/redoc) are disabled and
# logs are emitted as JSON.
ENVIRONMENT=development

# Async SQLAlchemy connection string (asyncpg driver).
# Local Docker Postgres:
#   postgresql+asyncpg://iotadmin:secretpassword@localhost:5432/iot_dms
# Supabase (use the SESSION pooler, port 5432 — nested transactions need it):
#   postgresql+asyncpg://postgres.<project-ref>:<db-password>@<pooler-host>:5432/postgres
DATABASE_URL=postgresql+asyncpg://iotadmin:secretpassword@localhost:5432/iot_dms

# Comma-separated list of allowed frontend origins for CORS.
# Production example: https://your-frontend.vercel.app,https://admin.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Supabase ----
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>   # SECRET — backend only, never expose
SUPABASE_JWT_AUDIENCE=authenticated

# ---- Admin bootstrap (used by scripts/create_admin.py) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                                      # set a strong password before bootstrapping

# ---- Telemetry alert thresholds (optional overrides) ----
ALERT_LOW_BATTERY_PCT=20.0
ALERT_HIGH_TEMP_C=65.0
ALERT_LOW_VOLTAGE_V=11.5

# ---- Offline watchdog (optional overrides) ----
# A device is marked OFFLINE (and a DEVICE_OFFLINE alert raised) after missing
# this many consecutive expected uploads (per-device upload_interval_seconds).
DEVICE_OFFLINE_GRACE_MULTIPLIER=3.0
# How often the background sweep runs, in seconds.
OFFLINE_WATCHDOG_INTERVAL_SECONDS=60
