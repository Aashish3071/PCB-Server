# ---- Root env for `docker compose` variable substitution ----
# Copy to .env (git-ignored). Only needed when running the full stack via
# docker-compose.yml. Managed-host deploys set these in the host dashboard instead.

# Postgres (the bundled db service)
POSTGRES_USER=iotadmin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=iot_dms

# Backend runtime + CORS (comma-separated origins the browser will use)
ENVIRONMENT=production
CORS_ORIGINS=http://localhost:8080

# Frontend build args (baked into the client bundle — public values only)
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>
